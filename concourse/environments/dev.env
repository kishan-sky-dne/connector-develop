# Environment variables for DEVELOP
# Used by deploy script for manifest substitution and runtime sizing.
# ENVIRONMENT, NAMESPACE, and KUBECONFIG are injected by pipeline params.

# Image details (set by CI/CD)
export IMAGE_REGISTRY="registry.cloud.sky"
export IMAGE_NAME="ipnd-dne/connectors"
export IMAGE_TAG="develop"  # Will be overridden by pipeline

# Deployment scaling
export REPLICAS="2"
export HPA_MIN_REPLICAS="2"
export HPA_MAX_REPLICAS="5"

# Resource requests and limits
export CPU_REQUEST="250m"
export CPU_LIMIT="1000m"
export MEMORY_REQUEST="512Mi"
export MEMORY_LIMIT="2Gi"

# Gateway/Ingress (CKS DNS pattern for on-prem onx cluster)
# Pattern: <app>.internal.<env>.shared.onx.uk-sky.cks.sky
export HOSTNAME="connectors.internal.dev.shared.onx.uk-sky.cks.sky"

# Note: Application configuration (LOG_LEVEL, DEBUG_MODE, TESTING_MODE, FLASK_ENV)
# and all secrets are stored in AWS Secrets Manager and created dynamically
# by the Concourse pipeline. They are NOT defined in this file.
