# Environment variables for STAGE
# Used by deploy script for manifest substitution and runtime sizing.
# ENVIRONMENT, NAMESPACE, and KUBECONFIG are injected by pipeline params.

export IMAGE_REGISTRY="registry.cloud.sky"
export IMAGE_NAME="ipnd-dne/connectors"
export IMAGE_TAG="stage"
export REPLICAS="3"
export HPA_MIN_REPLICAS="3"
export HPA_MAX_REPLICAS="10"
export CPU_REQUEST="1000m"
export CPU_LIMIT="4000m"
export MEMORY_REQUEST="2Gi"
export MEMORY_LIMIT="8Gi"
export HOSTNAME="connectors.internal.stage.shared.onx.uk-sky.cks.sky"

# Note: Application configuration and secrets are stored in AWS Secrets Manager
# See: ./setup/02-setup-aws-secrets.sh
