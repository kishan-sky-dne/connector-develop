{%- for line in mappings.templateAttributes %}
{%- if line.aEnd is defined and line.bEnd is not defined and line.circuitId is not defined %}
{{mappings.serviceName}} ({{line.aEnd}}) ----> {{line.status}}
{%- endif %}
{%- if line.aEnd is defined and line.bEnd is defined and line.circuitId is not defined %}
{{mappings.serviceName}} ({{line.aEnd}} - {{line.bEnd}}) ----> {{line.status}}
{%- endif %}
{%- if line.aEnd is defined and line.bEnd is defined and line.circuitId is defined %}
{{mappings.serviceName}} ({{line.aEnd}} - {{line.bEnd}} : circuit id {{line.circuitId}}) ----> {{line.status}}
{%- endif %}
{%- endfor %}